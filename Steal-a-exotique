end

-- =====================================================
-- TELEPORT
-- =====================================================
local function teleportToModel(model)

local char = player.Character  
if not char then return end  

local hrp = char:FindFirstChild("HumanoidRootPart")  
if not hrp then return end  

local part = model:FindFirstChildWhichIsA("BasePart",true)  
if not part then return end  

hrp.CFrame = part.CFrame * CFrame.new(0,0,-5)

end

-- =====================================================
-- HEIGHT CHECK
-- =====================================================
local function isHigh(model)

local part = model:FindFirstChildWhichIsA("BasePart",true)  
if not part then return false end  

return part.Position.Y - humanoidRootPart.Position.Y > 8

end

-- =====================================================
-- DISTANCE
-- =====================================================
local function getDistance(model)

local part = model:FindFirstChildWhichIsA("BasePart",true)  
if not part then return 0 end  

return (humanoidRootPart.Position - part.Position).Magnitude

end

-- =====================================================
-- STEAL LOOP
-- =====================================================
local running = false

local function startLoop()

while running do  

	local groundTargets = {}  
	local highTargets = {}  

	for _,brainrotName in ipairs(priorityBrainrots) do  

		local models = findBrainrot(brainrotName)  

		for _,model in pairs(models) do  

			if stolenBrainrots[model] then continue end  

			local dist = getDistance(model)  

			if dist < 8 then  
				continue  
			end  

			if isHigh(model) then  
				table.insert(highTargets,{model,brainrotName,dist})  
			else  
				table.insert(groundTargets,{model,brainrotName,dist})  
			end  

		end  

	end  

	table.sort(groundTargets,function(a,b)  
		return a[3] > b[3]  
	end)  

	table.sort(highTargets,function(a,b)  
		return a[3] > b[3]  
	end)  

	local function process(list)  

		for _,data in pairs(list) do  

			if not running then break end  

			local model = data[1]  
			local brainrotName = data[2]  

			statusLabel.Text = "Status: Stealing "..brainrotName  
			statusLabel.TextColor3 = Color3.fromRGB(0,255,120)  

			teleportToModel(model)  

			task.wait(0.3)  

			stolenBrainrots[model] = true  

			if savedPosition then  
				local char = player.Character  
				if char and char:FindFirstChild("HumanoidRootPart") then  
					char.HumanoidRootPart.CFrame = savedPosition  
				end  
			end  

			task.wait(0.1)  

		end  

	end  

	process(groundTargets)  
	process(highTargets)  

	task.wait(0.5)  

end

end

