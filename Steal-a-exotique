local function lerpColor(c1,c2,t)

return Color3.new(
c1.R+(c2.R-c1.R)*t,
c1.G+(c2.G-c1.G)*t,
c1.B+(c2.B-c1.B)*t
)

end

local function getProgressColor(progress)

if progress <= 0.25 then
return lerpColor(Color3.fromRGB(0,255,0),Color3.fromRGB(255,255,0),progress/0.25)

elseif progress <= 0.5 then
return lerpColor(Color3.fromRGB(255,255,0),Color3.fromRGB(255,165,0),(progress-0.25)/0.25)

elseif progress <= 0.75 then
return lerpColor(Color3.fromRGB(255,165,0),Color3.fromRGB(255,0,0),(progress-0.5)/0.25)

else
return Color3.fromRGB(255,0,0)
end

end

local progress = 0

local function updateBar(dt)

progress = math.clamp(progress + dt*4,0,1)

progressBg.Visible = true
progressFill.Size = UDim2.new(progress,0,1,0)
progressFill.BackgroundColor3 = getProgressColor(progress)

percentLabel.Text = math.floor(progress*100).."%"
percentLabel.Position = UDim2.new(progress,6,0,0)

end

local function resetBar()

progress = 0
progressBg.Visible = false
progressFill.Size = UDim2.new(0,0,1,0)
percentLabel.Text = "0%"
percentLabel.Position = UDim2.new(0,6,0,0)

end

