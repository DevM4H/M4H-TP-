local closestDist = math.huge

for _,prompt in pairs(CollectionService:GetTagged(AUTO_TAG)) do

if prompt.Enabled then

local dist = (rootPos - getPromptPosition(prompt)).Magnitude

if dist <= prompt.MaxActivationDistance and dist < closestDist then
closestDist = dist
closestPrompt = prompt
end

end

end

if closestPrompt then

